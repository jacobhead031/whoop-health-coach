WHOOP_CLIENT_ID=your-client-id
WHOOP_CLIENT_SECRET=your-client-secret
# Must exactly match a redirect URI registered on your WHOOP app
WHOOP_REDIRECT_URI=http://localhost:8765/callback
# Gmail address the coach sends prompts to (and reads your replies from)
GMAIL_ADDRESS=you@gmail.com
# Google App Password (myaccount.google.com/apppasswords) for coach_email.py
GMAIL_APP_PASSWORD=your-app-password
# Optional: IANA timezone for prompts/logging (default America/Toronto)
# COACH_TZ=America/Toronto
